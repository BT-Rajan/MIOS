# ===========================================
# MIOS - Manufacturing Intelligence OS
# Environment Configuration
# ===========================================

# -------------------------------------------
# Database Configuration (MySQL 8.0)
# -------------------------------------------
MYSQL_ROOT_PASSWORD=mios_root_2024_secure_change_in_prod
MYSQL_DATABASE=mios
MYSQL_USER=mios_user
MYSQL_PASSWORD=mios_pass_2024_secure_change_in_prod
DATABASE_URL=mysql+mysqlconnector://mios_user:mios_pass_2024_secure_change_in_prod@db:3306/mios

# -------------------------------------------
# Redis Configuration
# -------------------------------------------
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379

# -------------------------------------------
# Application Settings
# -------------------------------------------
APP_NAME=MIOS
APP_ENV=production
DEBUG=False
LOG_LEVEL=INFO
API_PREFIX=/api
VERSION=1.0.0

# -------------------------------------------
# Security & Authentication
# -------------------------------------------
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Password policy
MIN_PASSWORD_LENGTH=12
PASSWORD_REQUIRE_SPECIAL=True
PASSWORD_REQUIRE_NUMBER=True
PASSWORD_REQUIRE_UPPERCASE=True

# -------------------------------------------
# CORS Settings
# -------------------------------------------
CORS_ORIGINS=["http://localhost:3000","http://localhost:80","https://your-domain.com"]
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# -------------------------------------------
# Rate Limiting
# -------------------------------------------
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# -------------------------------------------
# Celery Configuration
# -------------------------------------------
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_SERIALIZER=json
CELERY_ACCEPT_CONTENT=[json]
CELERY_TIMEZONE=UTC

# -------------------------------------------
# File Upload Settings
# -------------------------------------------
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=/app/uploads
ALLOWED_EXTENSIONS=pdf,csv,xlsx,docx,txt,png,jpg,jpeg

# -------------------------------------------
# Audit & Compliance
# -------------------------------------------
AUDIT_ENABLED=True
AUDIT_RETENTION_DAYS=3650
AUDIT_IP_TRACKING=True
AUDIT_USER_AGENT=True

# -------------------------------------------
# Feature Flags
# -------------------------------------------
FEATURE_CONVERSATION_UI=True
FEATURE_ADVANCED_REPORTING=True
FEATURE_AUTO_APPROVAL=False
FEATURE_MULTI_WAREHOUSE=True

# -------------------------------------------
# Email Configuration (Optional)
# -------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=True
EMAIL_FROM=noreply@mios.local
EMAIL_ENABLED=False

# -------------------------------------------
# External Integrations (Disabled by default)
# -------------------------------------------
ENABLE_EXTERNAL_AI=False
EXTERNAL_AI_ENDPOINT=
EXTERNAL_AI_API_KEY=

# -------------------------------------------
# Monitoring & Observability
# -------------------------------------------
ENABLE_METRICS=True
METRICS_ENDPOINT=/metrics
HEALTH_CHECK_ENABLED=True

# -------------------------------------------
# Session Management
# -------------------------------------------
SESSION_COOKIE_NAME=mios_session
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=lax

# -------------------------------------------
# Database Pool Settings
# -------------------------------------------
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
