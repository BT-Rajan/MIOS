"""
Environment configuration template.

Copy to .env and configure for your environment.
"""

# Application
APP_NAME=MIOS
APP_VERSION=1.0.0
DEBUG=false

# Database
DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/mios
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Security
JWT_SECRET_KEY=change-this-in-production-use-secure-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30

# Encryption
ENCRYPTION_KEY=

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
